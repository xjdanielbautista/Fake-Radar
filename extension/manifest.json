{
  "manifest_version": 3,
  "name": "Fake Radar Extension",
  "version": "0.1",
  "description": "Detector de Fake News y Clickbait",
  "permissions": ["contextMenus", "storage", "activeTab"],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}